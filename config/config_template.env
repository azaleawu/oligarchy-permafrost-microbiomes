# Template configuration for upstream metagenome and MAG workflow.
# Copy this file to config.env and edit paths before use.

THREADS=32
MEMORY_GB=128

# Input and output directories
READ_DIR="data/raw_reads"
OUT_DIR="results/upstream"
TMP_DIR="results/tmp"

# Sample table: tab-delimited with columns sample_id,read1,read2
SAMPLE_TABLE="config/sample_table_template.tsv"

# MAG table: tab-delimited with columns mag_id,fasta
MAG_TABLE="config/mag_table_template.tsv"

# External databases; set these to local database locations
CARD_DB="/path/to/card_database"
VFDB_DB="vfdb"
GTDBTK_DATA_PATH="/path/to/gtdbtk/release"
CHECKM2_DB="/path/to/checkm2_database"

# Software options
MEGAHIT_PRESET="meta-sensitive"
MIN_CONTIG_LEN=500
RGI_CUTOFF="perfect,strict"
ARG_MIN_IDENTITY=80
ARG_MIN_COVERAGE=80
VF_MIN_IDENTITY=70
VF_MIN_COVERAGE=70
