# User-editable configuration file
# Edit these paths before running the scripts.

# Base directories
PROJECT_DIR="$(pwd)"
RAW_READ_DIR="${PROJECT_DIR}/data/raw_reads"
WORK_DIR="${PROJECT_DIR}/results/work"
OUT_DIR="${PROJECT_DIR}/results/processed"
LOG_DIR="${PROJECT_DIR}/results/logs"

# Computational resources
THREADS=32

# Databases
CHECKM2_DB="/path/to/CheckM2_database/uniref100.KO.1.dmnd"
GTDBTK_DATA_PATH="/path/to/gtdbtk/release226"
CARD_JSON="/path/to/CARD/card.json"
VFDB_DB_NAME="vfdb"

# Software parameters
MIN_CONTIG_LEN=500
VAMB_MINFASTA=50000
DREP_PRIMARY_ANI=0.90
DREP_SECONDARY_ANI=0.95
DREP_COVERAGE=0.10
MAG_COMPLETENESS=50
MAG_CONTAMINATION=10
RGI_MIN_IDENTITY=80
RGI_MIN_COVERAGE=80
VFDB_MIN_IDENTITY=70
VFDB_MIN_COVERAGE=70
